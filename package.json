{
  "name": "guess",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "kill": "fuser -k 5000/tcp",
    "build": "tsc -b --noCheck && vite build",
    "lint": "eslint .",
    "optimize": "vite optimize",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler pages deploy",
    "deploy:preview": "pnpm build && wrangler pages deploy --branch preview",
    "cf:login": "wrangler login",
    "cf:dev": "pnpm build && wrangler pages dev dist",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'src/components/**'",
    "test:components": "vitest run src/components/",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "validate": "tsc -b && eslint . && vitest run",
    "size": "size-limit",
    "db:types": "tsx scripts/generate-db-types.ts",
    "migrate:create": "tsx scripts/create-migration.ts",
    "migrate:preview": "wrangler d1 migrations apply guess-db-preview --env preview --remote",
    "migrate:prod": "wrangler d1 migrations apply guess-db --env production --remote",
    "db:clone-to-preview": "zsh scripts/clone-prod-to-preview.sh",
    "analytics:readiness:preview": "wrangler d1 execute guess-db-preview --env preview --remote --file docs/guess-readiness-queries.sql",
    "analytics:readiness:prod": "wrangler d1 execute guess-db --env production --remote --file docs/guess-readiness-queries.sql",
    "analytics:sim:preview": "wrangler d1 execute guess-db-preview --env preview --remote --file docs/sim-calibration-queries.sql",
    "analytics:sim:prod": "wrangler d1 execute guess-db --env production --remote --file docs/sim-calibration-queries.sql",
    "simulate:analyze": "tsx scripts/simulate/analyze.ts",
    "ingest": "tsx scripts/ingest/run.ts",
    "ingest:stats": "tsx scripts/ingest/run.ts stats",
    "ingest:dedup": "tsx scripts/ingest/run.ts dedup",
    "ingest:upload": "tsx scripts/ingest/run.ts upload",
    "simulate:export": "tsx scripts/simulate/export-data.ts",
    "simulate": "tsx scripts/simulate/run.ts",
    "simulate:grid": "tsx scripts/simulate/grid-search.ts",
    "simulate:compare": "tsx scripts/simulate/compare.ts",
    "simulate:regression": "tsx scripts/simulate/regression.ts",
    "simulate:apply-weights": "tsx scripts/simulate/apply-weights.ts",
    "simulate:race": "tsx scripts/simulate/race.ts",
    "simulate:maybe-rates": "tsx scripts/simulate/export-maybe-rates.ts",
    "simulate:net-gains": "tsx scripts/simulate/export-net-gains.ts",
    "simulate:confusion-pairs": "tsx scripts/simulate/confusion-pairs.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@guess/game-engine": "workspace:*",
    "@phosphor-icons/react": "^2.1.7",
    "@radix-ui/react-alert-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/vite": "^4.1.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.12.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.0.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.2.4",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-app": "^12.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-v8": "^4.1.5",
    "better-sqlite3": "^12.9.0",
    "eslint": "^10.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.6",
    "sharp": "^0.34.5",
    "size-limit": "^12.0.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.86.0"
  },
  "size-limit": [
    {
      "name": "vendor-ui",
      "path": "dist/assets/vendor-ui-*.js",
      "limit": "100 kB",
      "gzip": true
    },
    {
      "name": "vendor-charts",
      "path": "dist/assets/vendor-charts-*.js",
      "limit": "115 kB",
      "gzip": true
    },
    {
      "name": "vendor-motion",
      "path": "dist/assets/vendor-motion-*.js",
      "limit": "50 kB",
      "gzip": true
    }
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "fast-xml-parser": ">=5.7.0"
    }
  }
}
